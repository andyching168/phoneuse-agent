# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Z.AI MaaS API Key (for screen_overview --provider api, set USE_LOCAL_GLM_OCR=false to enable)
# 請到此申請：https://z.ai 或聯繫 Z.AI 取得 API Key
ZAI_API_KEY=your_zai_api_key_here

# Optional: Override default settings
# GEMINI_MODEL=gemini-2.0-flash
# OLLAMA_API_URL=http://192.168.0.212:11434/api/chat
# OLLAMA_MODEL=qwen3.5:0.8b
# USE_LOCAL_GLM_OCR=false  # Set to false to use Z.AI MaaS API instead of local model
